.DS_Store

# Ignore editor directories and files.
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Ignore node modules.
node_modules

# Ignore cache/output directories.
build
dist
out

# Ignore environment variables.
# All env files — including .env.example templates — are gitignored to prevent
# leaking real secrets through "example" files. Share env shape via docs or a
# separate sanitized template kept outside this directory.
*.env*

# Ignore worktrees.
.worktrees

# Scratch TS narrowing experiments at repo root.
/test-narrowing*.ts
