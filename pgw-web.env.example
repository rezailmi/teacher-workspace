RESIZED_IMAGE_DRAFT_URL=https://localhost/resized-draft
RESIZED_IMAGE_REDIRECT_URL=https://localhost/resized-redirect
NATIVE_CHECKSUM_BUCKET=

# --- WOGAA (placeholder URLs for CSP — helmet requires non-empty values) ---
WOGAA_CSP=https://localhost
WOGAA_CSP_ASSETS=https://localhost
WOGAA_SCRIPT=https://localhost
WOGAA_CREATE_CG_FILE_UPLOAD_TID=
WOGAA_SEARCH_FILTER_ANN_CF_TID=
